release:
name: Workflow Release
on:
  push:
    paths-ignore:
      - '**.md'
      - '.github/**'
    branches:
      - main
      - develop
      - release/**
  repository_dispatch:
    types: [deployment-release]

jobs:
  call-build:
    if: github.event_name != 'repository_dispatch'

    uses: 
    with:
      enabled-fortify: ${{ vars.G_FORTIFY_SAST_RELEASE_ENABLED }}
      enabled-sonar: ${{ vars.G_SONARQUBE_RELEASE_ENABLED }}
      #enabled-dp_check: ${{ vars.G_DCHECK_RELEASE_ENABLED }}
      #enabled-tenable: ${{ vars.G_TENABLE_RELEASE_ENABLED }}
      enabled-acs: ${{ vars.G_ACS_RELEASE_ENABLED }}
      enabled-mend: ${{ vars.G_MEND_RELEASE_ENABLED }}
      java-version: "${{ vars.LANGUAGE_VERSION }}"
      # Skip due in release will run pass HOM and PRD destination-environment
    secrets: inherit

  call-deploy-hom:
    # Skip deploy to HOM if hotfix
    if: ${{ ! startsWith(github.ref, 'cherry-picked-hotfix/') }}
    needs: call-build
    uses: Bradesco-Core/reusable-workflows/.github/workflows/java-deploy-release.yaml@latest
    with:
        image-version: ${{ needs.call-build.outputs.image-version }}
        app-version: ${{ needs.call-build.outputs.app-version }}
        environment: 'HOM'
    secrets: inherit

  call-tests-hom:
    if: success() || ( startsWith(github.ref, 'cherry-picked-hotfix/') && needs.call-build.outputs.issue-key != '' )
    needs: [ call-build, call-deploy-hom ]
    uses: Bradesco-Core/reusable-workflows/.github/workflows/java-test-execution-automation-xray.yaml@latest
    with:
      issuekey: ${{ needs.call-build.outputs.issue-key }}
      environment: 'HOM'
      java-version: "${{ vars.LANGUAGE_VERSION }}"
    secrets: inherit
    
  call-change-velocity:
    if: success() || ( startsWith(github.ref, 'cherry-picked-hotfix/') && needs.call-build.result == 'success')
    needs: [ call-build, call-deploy-hom ]
    uses: Bradesco-Core/reusable-workflows/.github/workflows/java-change-velocity.yaml@latest
    with:
        package-name: ${{ needs.call-build.outputs.package-name }}
        version: ${{ needs.call-build.outputs.app-version }}
        sonar-project-key: ${{ needs.call-build.outputs.sonar-project-key }}
        acs-base-report: ${{ needs.call-build.outputs.acs-base-report }}
        acs-app-report: ${{ needs.call-build.outputs.acs-app-report }}
        mend-report: ${{ needs.call-build.outputs.mend-report }}
        fortify-report: ${{ needs.call-build.outputs.fortify-report }}
    secrets: inherit

  call-deploy-prd:
    if: success() || ( startsWith(github.ref, 'cherry-picked-hotfix/') && needs.call-build.result == 'success' )
    needs: [ call-change-velocity, call-build, call-deploy-hom ]
    uses: Bradesco-Core/reusable-workflows/.github/workflows/java-deploy-release.yaml@latest
    with:
        image-version: 
        app-version: 
        environment: 'PRD'
    secrets: inherit

  call-deploy-infra-hom:
    if: github.event.client_payload.ref_name == 'staging'
    uses: 
    with:
        environment: 'HOM'
        only-config: 'true'
    secrets: inherit

  call-deploy-infra-prd:
    if: github.event.client_payload.ref_name == 'production'
    uses:
    with:
        environment: 'PRD'
        only-config: 'true'
    secrets: inherit
sandbox
name: Workflow Sandbox
on:
  repository_dispatch:
    types: [deployment-sandbox]

  workflow_dispatch:
    inputs:
      build-deploy:
        description: "O que deseja fazer?"
        required: false
        default: Somente Build
        type: choice
        options:
          - Somente Build
          - Build + Deploy
          - Atualizacao values.yaml
      enabled-fortify:
        description: "Habilitar Fortify SAST"
        required: false
        default: true
        type: boolean

#      enabled-dependecy_check:
#        description: "Habilitar Dependency Check"
#        required: false
#        default: true
#        type: choice
#        options:
#          - true
#          - false

      enabled-sonar:
        description: "Habilitar testes Sonarqube"
        required: false
        default: true
        type: boolean

      enabled-acs:
        description: "Habilitar Scan de Imagem ACS"
        required: false
        default: true
        type: boolean

      enabled-mend:
        description: "Habilitar Scan Mend"
        required: true
        default: true
        type: boolean

jobs:
  call-build:
    if: ${{ github.event_name != 'repository_dispatch' && inputs.build-deploy != 'Atualizacao values.yaml' }}
    uses: Bradesco-Core/reusable-workflows/.github/workflows/java-maven-build-sandbox.yaml@latest
    with:
      enabled-fortify: ${{ inputs.enabled-fortify }}
      enabled-sonar: ${{ inputs.enabled-sonar }}
#       enabled-dp_check: ${{ inputs.enabled-dependecy_check }}
      java-version: "${{ vars.LANGUAGE_VERSION }}"
      enabled-acs: ${{ inputs.enabled-acs }}
      enabled-mend: ${{ inputs.enabled-mend }}
    secrets: inherit

  call-deploy-dev:
    needs: call-build
    if: ${{ inputs.build-deploy != 'Somente Build' }}
    uses: Bradesco-Core/reusable-workflows/.github/workflows/java-deploy-sandbox.yaml@latest
    with:
        image-version: ${{ needs.call-build.outputs.image-version }}
        app-version: ${{ needs.call-build.outputs.app-version }}
        environment: 'DEV'
        only-config: 'false'
    secrets: inherit

  call-deploy-infra-dev:
    if: ${{ inputs.build-deploy == 'Atualizacao values.yaml' || github.event.client_payload.ref_name == 'sandbox' }}
    uses: Bradesco-Core/reusable-workflows/.github/workflows/java-deploy-sandbox.yaml@latest
    with:
        environment: 'DEV'
        only-config: 'true'
    secrets: inherit
pr check:
name: Workflow Pull Request Check
on:
  pull_request:
    types: [opened, synchronize]
    branches:
      - develop
      - main

jobs:
  merge-check:
    uses: Bradesco-Core/reusable-workflows/.github/workflows/java-maven-build-sandbox.yaml@latest
    with:
      enabled-fortify: ${{ vars.G_FORTIFY_SAST_RELEASE_ENABLED == 'true' }}
      enabled-sonar: ${{ vars.G_SONARQUBE_RELEASE_ENABLED == 'true' }}
#       enabled-dp_check: ${{ vars.G_DCHECK_RELEASE_ENABLED == 'true' }}
      java-version: "${{ vars.LANGUAGE_VERSION }}"
      enabled-mend: ${{ vars.G_MEND_RELEASE_ENABLED == 'true' }}
      enabled-acs: ${{ vars.G_ACS_RELEASE_ENABLED == 'true' }}
      only-check: true
    secrets: inherit

rollback:

name: Workflow Rollback
run-name: Rollback version tag ${{ inputs.image-tag}} in ${{ inputs.environment }} - ${{ inputs.change-number }}
on:
  workflow_dispatch:
    inputs:
      image-tag:
        description: "Informe para qual tag deseja realizar o Rollback"
        required: true
        type: string
      environment:
        description: "Informe o Ambiente em que deseja realizar o rollback"
        required: true
        type: choice
        options:
          - HOM
          - PRD
jobs:
  call-rollback:
    uses: Bradesco-Core/reusable-workflows/.github/workflows/microservice-rollback.yaml@latest
    with:
        image-version: ${{ inputs.image-version }}
        environment: ${{ inputs.environment }}
    secrets: inherit
ci:
name: Workflow Testes Automatizados
on:
  workflow_dispatch:
    inputs:
      testExecKey:
        description: 'Test Execution Key'
        required: true
        default: ''
        type: "string"
      environment:
        description: "Environment"
        required: true
        default: ""
        type: "choice"
        options:
          - DEV
          - HOM
      javaVersion:
        description: "Java version"
        required: true
        default: "11"
        type: "choice"
        options:
          - 11
          - 17

jobs:
  call-build:
    uses: Bradesco-Core/reusable-workflows/.github/workflows/java-test-automation.yaml@latest
    with:
      testExecKey:  ${{ inputs.testExecKey }}
      environment:  ${{ inputs.environment }}
      javaVersion:  ${{ inputs.javaVersion }}
    secrets: inherit
